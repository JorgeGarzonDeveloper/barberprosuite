# ============================================================
# BARBERPROSUITE - Environment Variables
# ============================================================
# Copia este archivo a .env y completa los valores reales

# --- App ---
NODE_ENV=development
APP_PORT=3000
APP_URL=http://localhost:3000
WEB_URL=http://localhost:3001

# --- Base de datos (PostgreSQL) ---
DATABASE_URL=postgresql://barber_user:barber_pass@localhost:5432/barberprosuite
DB_HOST=localhost
DB_PORT=5432
DB_NAME=barberprosuite
DB_USER=barber_user
DB_PASSWORD=barber_pass

# --- Redis (cola virtual + cache + sesiones) ---
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- JWT ---
JWT_SECRET=d2792d648853fa9366f2083b5ce8168884371ce2ac62a5caf60232d752e68b65ef4d98ff70d30f70f8f6cef8a50c17807861b8cb79581a88175c6c33fbd84479
JWT_EXPIRY=7d
JWT_REFRESH_SECRET=6cf0689150e1ec0ee54e2f92301e813807913c8ae5be33401f6fa980dfd07c3024cda652a33438c2c89b6d817511413b8261e275bfa634622ddc26b347b599e8
JWT_REFRESH_EXPIRY=30d

# --- Firebase (notificaciones push) ---
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com

# --- Google Maps ---
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key-for-frontend

# --- Pasarela de pagos (Wompi - Colombia) ---
WOMPI_PUBLIC_KEY=pub_test_...
WOMPI_PRIVATE_KEY=prv_test_...
WOMPI_INTEGRITY_KEY=test_integrity_...
WOMPI_WEBHOOK_SECRET=your-webhook-secret

# --- AWS S3 (almacenamiento de imágenes) ---
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_S3_BUCKET=barberprosuite-media

# --- Email (SendGrid o SMTP) ---
SENDGRID_API_KEY=SG.your-sendgrid-api-key
EMAIL_FROM=noreply@barberprosuite.com
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587

# --- SMS (Twilio) ---
TWILIO_ACCOUNT_SID=ACyour-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+15551234567

# --- Rate Limiting ---
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# --- Geofencing ---
QUEUE_GEOFENCE_RADIUS_METERS=500

# --- QR Codes ---
QR_SECRET=cdfb22122d2385f13738e4ce66b704c03be29c03b295e83da51c0701cc0a04097d446c946d535fe4efeab49f40d64a576f89ad253d871b43f187d4ea6e073f96

# --- Nequi ---
NEQUI_CLIENT_ID=your_nequi_client_id
NEQUI_CLIENT_SECRET=your_nequi_client_secret
NEQUI_COMMERCE_CODE=your_nequi_commerce_code
